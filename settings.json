{
    "vscode_custom_css.imports": ["file://${userHome}/.config/Code/User/custom.css"],
    "workbench.startupEditor": "none",
    "workbench.activityBar.location": "top",
    "workbench.editor.empty.hint": "hidden",
    "window.menuBarVisibility": "hidden",
    "window.commandCenter": false,
    "claudeCode.preferredLocation": "sidebar",
    "terminal.integrated.altClickMovesCursor": false,
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,
    "terminal.integrated.allowMnemonics": true,
    "workbench.colorTheme": "Dark Modern",
    "editor.minimap.enabled": false,
    "terminal.integrated.initialHint": false,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.shellIntegration.decorationsEnabled": "never",
    "terminal.integrated.commandsToSkipShell": [
        "workbench.action.createTerminalEditor",
        "workbench.action.focusSideBar",
        "workbench.view.explorer",
        "workbench.action.files.newUntitledFile"
    ],
    "git.autofetch": true,
    "claudeCode.spinnerVerbs": {
        "mode": "replace",
        "verbs": ["Working"]
    },
    "editor.stickyScroll.enabled": false,
    "editor.lightbulb.enabled": "off",
    "editor.renderLineHighlight": "none",
    "editor.matchBrackets": "near",
    "editor.occurrencesHighlight": "off",
    "debug.javascript.codelens.npmScripts": "never",
    "terminal.integrated.cursorStyleInactive": "none",
    "explorer.confirmDragAndDrop": false,
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "off"
    },
    "terminal.integrated.stickyScroll.enabled": false,
    "git.openRepositoryInParentFolders": "never",
    "diffEditor.ignoreTrimWhitespace": false,
    "explorer.confirmDelete": false,
    "terminal.integrated.shellIntegration.quickFixEnabled": false,
    "editor.pasteAs.showPasteSelector": "never",
    "debug.gutterMiddleClickAction": "none",
    "editor.mouseMiddleClickAction": "openLink",
    "editor.emptySelectionClipboard": false,
    "editor.selectionClipboard": false,
    "editor.multiCursorModifier": "ctrlCmd",
    "explorer.confirmPasteNative": false,
    "workbench.editorAssociations": {
        "*.svg": "default"
    },
    "workbench.browser.openLocalhostLinks": false,
    "terminal.integrated.scrollback": 100000,
    "github.copilot.enable": {
        "*": true
    },
    "git.confirmSync": false,
    "git.enableSmartCommit": true
}
